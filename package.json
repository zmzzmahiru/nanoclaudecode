{
  "name": "nanoclaude",
  "version": "1.0.0",
  "description": "A lightweight TypeScript coding-agent CLI with safe patch editing, permissioned tools, traces, and local evals.",
  "main": "dist/index.js",
  "bin": {
    "nanoclaude": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx eval/run-eval.ts"
  },
  "keywords": [
    "ai-agent",
    "coding-agent",
    "typescript",
    "cli",
    "llm",
    "openai-compatible",
    "tool-calling",
    "evals"
  ],
  "author": "zmzzmahiru",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "dotenv": "^17.4.2",
    "openai": "^6.38.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "tsx": "^4.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
